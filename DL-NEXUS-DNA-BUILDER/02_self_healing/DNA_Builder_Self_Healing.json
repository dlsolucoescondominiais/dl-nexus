{
  "name": "DNA_Builder_Self_Healing",
  "nodes": [
    {
      "parameters": {},
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const execution = $input.all()[0].json.data ? $input.all()[0].json.data[0] : $input.all()[0].json;\nconst errorMsg = execution?.data?.resultData?.error?.message || execution?.error?.message || (execution?.credential_name ? 'CREDENCIAL_EXPIRANDO' : 'Unknown error');\nlet type = 'UNKNOWN';\n\nif (errorMsg === 'CREDENCIAL_EXPIRANDO' || errorMsg.includes('credentials') || errorMsg.includes('expired') || errorMsg.includes('unauthorized') || errorMsg.includes('401')) type = 'CREDENCIAL_EXPIRADA';\nelse if (errorMsg.includes('rate limit') || errorMsg.includes('429')) type = 'API_RATE_LIMIT';\nelse if (errorMsg.includes('timeout') || errorMsg.includes('ESOCKETTIMEDOUT')) type = 'TIMEOUT';\nelse if (errorMsg.includes('permission') || errorMsg.includes('forbidden') || errorMsg.includes('403')) type = 'PERMISSAO_NEGADA';\nelse type = 'NODE_QUEBRADO';\n\nreturn { json: { workflow_id: execution.workflowId || execution.id || 'N/A', error_message: errorMsg, type: type, credential_name: execution?.credential_name } };"
      },
      "name": "Classify Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.type }}",
        "rules": {
          "rules": [
            {
              "value2": "CREDENCIAL_EXPIRADA"
            },
            {
              "value2": "API_RATE_LIMIT"
            },
            {
              "value2": "TIMEOUT"
            },
            {
              "value2": "PERMISSAO_NEGADA"
            },
            {
              "value2": "NODE_QUEBRADO"
            }
          ]
        }
      },
      "name": "Switch Type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "operation": "insert",
        "schema": "public",
        "table": "dl_nexus_agent_logs",
        "columns": "workflow_id, action, status, error_details",
        "workflow_id": "={{ $json.workflow_id }}",
        "action": "={{ 'HEAL_' + $json.type }}",
        "status": "ATTEMPTED",
        "error_details": "={{ JSON.stringify({ message: $json.error_message }) }}",
        "mappingMode": "defineBelow"
