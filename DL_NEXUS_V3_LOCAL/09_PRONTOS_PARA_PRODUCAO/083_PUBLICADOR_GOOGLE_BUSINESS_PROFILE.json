            },
            {
              "name": "callToAction",
              "value": "={{ { actionType: 'LEARN_MORE', url: 'https://share.google/NGEzAoHXg890EjyiR' } }}"
            }
          ]
        },
        "options": {}
      },
      "id": "http-google-publish",
      "name": "Publish to Google",
      "type": "n8n-nodes-base.httpRequest",
