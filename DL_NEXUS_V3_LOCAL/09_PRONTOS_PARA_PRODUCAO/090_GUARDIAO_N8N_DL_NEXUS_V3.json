      "name": "Buscar Execuções com Falha",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        850,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "id_header_auth_n8n",
          "name": "N8N_API_KEY_HEADER"
        }
