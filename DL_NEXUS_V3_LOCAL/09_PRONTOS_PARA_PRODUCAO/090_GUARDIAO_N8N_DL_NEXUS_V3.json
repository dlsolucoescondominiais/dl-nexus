      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "// Classificar falhas baseadas nas execucoes\nconst executions = items[0]?.json?.data || [];\nlet falhasClassificadas = [];\n\nfor (const exec of executions) {\n  let falha = { id: exec.id, workflowId: exec.workflowId, error: exec.error || {}, classificacao: 'ERRO_DESCONHECIDO' };\n  let errorString = JSON.stringify(exec.error || '').toLowerCase();\n  \n  if (errorString.includes('unauthorized') || errorString.includes('credential')) {\n    falha.classificacao = 'CREDENCIAL_AUSENTE';\n  } else if (errorString.includes('expired')) {\n    falha.classificacao = 'TOKEN_EXPIRADO';\n  } else if (errorString.includes('timeout') || errorString.includes('econnrefused')) {\n    falha.classificacao = 'WEBHOOK_SEM_RESPOSTA';\n  } else if (errorString.includes('json')) {\n    falha.classificacao = 'JSON_INVALIDO';\n  } else if (errorString.includes('meta') && errorString.includes('restrict')) {\n    falha.classificacao = 'META_API_RESTRITA';\n  } else if (errorString.includes('google') && errorString.includes('denied')) {\n    falha.classificacao = 'GOOGLE_API_REQUEST_DENIED';\n  } else if (errorString.includes('deepseek') && (errorString.includes('balance') || errorString.includes('insufficient'))) {\n    falha.classificacao = 'DEEPSEEK_SALDO_INSUFICIENTE';\n  } else if (errorString.includes('restart loop')) {\n    falha.classificacao = 'CONTAINER_RESTART_LOOP';\n  } else if (!exec.workflowId) {\n    falha.classificacao = 'WORKFLOW_SEM_ID';\n  }\n  \n  falhasClassificadas.push(falha);\n}\n\nreturn [{ json: { falhasClassificadas, count: falhasClassificadas.length } }];"
      },
      "id": "node-classificar-falhas",
      "name": "CLASSIFICAR_FALHAS_N8N",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1050,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const falhas = items[0]?.json?.falhasClassificadas || [];\n\nconst relatorio = {\n  status_geral: falhas.length > 0 ? (falhas.length > 10 ? 'CRITICO' : 'ATENCAO') : 'OK',\n  total_workflows: items[0]?.json?.count || 0,\n  workflows_com_erro: falhas.map(f => f.workflowId),\n  falhas_classificadas: falhas,\n  acoes_recomendadas: falhas.length > 0 ? ['Verificar nodes com erro reportados', 'Revisar credenciais se houver CREDENCIAL_AUSENTE'] : [],\n  acoes_bloqueadas_sem_aprovacao: ['Nenhuma alteracao automatica em producao foi feita', 'Nenhum workflow foi desativado'],\n  timestamp: new Date().toISOString()\n};\n\nreturn [{ json: relatorio }];"
      },
      "id": "node-gerar-relatorio",
      "name": "GERAR_RELATORIO_TECNICO",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1250,
        300
      ]
    },
    {
