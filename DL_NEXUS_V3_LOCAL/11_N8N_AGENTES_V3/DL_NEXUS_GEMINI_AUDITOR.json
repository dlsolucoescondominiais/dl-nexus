    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.choices[0].message.content}}",
              "operation": "contains",
              "value2": "APROVADO"
            }
          ]
        }
      },
      "id": "if-approved",
      "name": "IF Approved?",
