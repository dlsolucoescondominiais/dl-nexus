    {
      "parameters": {
        "jsCode": "// Normalizar payload de entrada\nconst body = $input.first().json.body || $input.first().json;\n\nconst nome = body.nome || body.name || 'Lead Desconhecido';\nconst telefone = body.telefone || body.phone || body.whatsapp || '';\nconst email = body.email || '';\nconst mensagem = body.mensagem || body.message || body.texto || '';\nconst origem = body.origem || body.source || 'webhook-direto';\nconst condominio = body.condominio || body.condo || '';\nconst servico = body.servico || body.service || body.tipo || '';\nconst urgencia = body.urgencia || body.priority || 'normal';\nconst timestamp = new Date().toISOString();\n\n// Classificar tipo de suporte\nlet tipo_suporte = 'geral';\nconst msg = mensagem.toLowerCase();\n\nif (msg.includes('solar') || msg.includes('energia') || msg.includes('fotovoltaic')) {\n  tipo_suporte = 'energia_solar';\n} else if (msg.includes('cftv') || msg.includes('c\u00e2mera') || msg.includes('camera') || msg.includes('seguran\u00e7a')) {\n  tipo_suporte = 'cftv_seguranca';\n} else if (msg.includes('el\u00e9tric') || msg.includes('eletric') || msg.includes('disjuntor') || msg.includes('curto')) {\n  tipo_suporte = 'eletrica';\n} else if (msg.includes('automa\u00e7\u00e3o') || msg.includes('automacao') || msg.includes('port\u00e3o') || msg.includes('portao')) {\n  tipo_suporte = 'automacao';\n} else if (msg.includes('inc\u00eandio') || msg.includes('incendio') || msg.includes('extint') || msg.includes('bombeiro')) {\n  tipo_suporte = 'prevencao_incendio';\n}\n\n// KILLCRITIC \u2014 Termos proibidos na mensagem (auditoria)\nconst termosProibidos = ['visita t\u00e9cnica', 'visita tecnica', 'canaleta pl\u00e1stica', 'canaleta plastica', 'engenheiro'];\nconst infracoes = termosProibidos.filter(t => msg.includes(t));\nconst killcritic_aprovado = infracoes.length === 0;\n\nreturn [{\n  json: {\n    nome,\n    telefone,\n    email,\n    mensagem,\n    origem,\n    condominio,\n    servico,\n    tipo_suporte,\n    urgencia,\n    timestamp,\n    killcritic_aprovado,\n    killcritic_infracoes: infracoes,\n    lead_id: `diego-sup-${Date.now()}`\n  }\n}];"
      },
