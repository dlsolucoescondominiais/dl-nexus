        "jsCode": "// Log de erro para auditoria\nconst error = $input.first().json;\nconst timestamp = new Date().toISOString();\n\nconsole.log(`[ERRO DIEGO SUPORTE] ${timestamp}:`, JSON.stringify(error));\n\nreturn [{\n  json: {\n    alerta: 'ERRO no workflow Diego Suporte T\u00e9cnico',\n    timestamp,\n    erro: error.message || JSON.stringify(error),\n    workflow: '003_roteador_diego_v3_tecnico_suporte',\n    acao: 'Verificar logs do n8n e corrigir'\n  }\n}];"
