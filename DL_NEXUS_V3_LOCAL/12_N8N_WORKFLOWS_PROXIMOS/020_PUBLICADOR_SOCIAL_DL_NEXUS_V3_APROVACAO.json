        "jsonOutput": "{\n  \"tema\": \"Manuten\u00e7\u00e3o Preventiva de Bombas\",\n  \"produto\": \"DL Acqua\",\n  \"publico_alvo\": \"S\u00edndicos e Administradoras\",\n  \"bairro\": \"Tijuca\",\n  \"canal_destino\": \"Facebook, Instagram, Telegram\",\n  \"objetivo\": \"Gerar engajamento e agendar Avalia\u00e7\u00e3o T\u00e9cnica\",\n  \"image_url\": \"https://dlsolucoescondominiais.com.br/wp-content/uploads/2023/10/dl-acqua.jpg\"\n}",
        "options": {},
        "values": {
          "boolean": [
            {
              "name": "DRY_RUN",
              "value": true
            }
          ]
        }
      },
      "id": "set_entrada",
      "name": "Entrada do Post",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        200,
        0
      ]
    },
    {
      "parameters": {
        "model": "gpt-4o-mini",
        "messages": {
          "messageValues": [
            {
              "content": "Voc\u00ea \u00e9 o copywriter da DL Solu\u00e7\u00f5es Condominiais. Escreva posts B2B profissionais. O CTA DEVE ser sempre 'Avalia\u00e7\u00e3o T\u00e9cnica'."
            },
            {
              "role": "user",
              "content": "={{ 'Tema: ' + $json.tema + '\\nProduto: ' + $json.produto + '\\nP\u00fablico: ' + $json.publico_alvo + '\\nBairro/Regi\u00e3o: ' + $json.bairro + '\\nCanal: ' + $json.canal_destino + '\\nObjetivo: ' + $json.objetivo + '\\n\\nCanais Oficiais DL Solu\u00e7\u00f5es (use sempre no CTA):\\n- Site: https://dlsolucoescondominiais.com\\n- Instagram: https://www.instagram.com/dl.solucoescondominiais/\\n- Facebook: https://www.facebook.com/dlsolucoescondominiais\\n- YouTube: https://www.youtube.com/@DLSolucoesCondominiais\\n- Google Perfil: https://share.google/NGEzAoHXg890EjyiR\\n- Spotify: https://open.spotify.com/episode/2yIqmHsnKLhFF76XKR1j2u?si=aMBi9LKJRZO1tlgxACWhDg&nd=1&dlsi=3b72e847f2044e18\\n- WhatsApp CTA (link passivo, n\u00e3o disparar): https://wa.me/5521964742458?text=Quero+saber+sobre+Recupera%C3%A7%C3%A3o+de+Dados\\n\\nRegras obrigat\u00f3rias:\\n- O CTA DEVE sempre ser \"Avalia\u00e7\u00e3o T\u00e9cnica\".\\n- Diogo deve ser chamado de \"Tecn\u00f3logo Respons\u00e1vel\", nunca de engenheiro.\\n- Incluir o link do WhatsApp como bot\u00e3o de contato no final de cada post.\\n- N\u00c3O prometer pre\u00e7o final, garantia vital\u00edcia ou visita t\u00e9cnica.\\n\\nForne\u00e7a uma resposta em JSON estrito com as chaves: legenda_facebook, legenda_instagram, texto_telegram, hashtags, cta' }}"
            }
          ]
        },
        "options": {},
        "resource": "chat",
        "operation": "create"
      },
      "id": "gerar_textos_ia",
      "name": "Gerar Textos IA",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.1,
      "position": [
        400,
        0
      ],
      "credentials": {}
    },
    {
      "parameters": {
        "jsCode": "const entrada = $('Entrada do Post').item.json || {};\nlet conteudo = $json.message ? $json.message.content : (typeof $json === 'string' ? $json : JSON.stringify($json));\n\nlet parsed = {};\nlet status_parse = 'SUCESSO';\nlet observacao = 'JSON parseado com sucesso.';\n\ntry {\n  const jsonMatch = conteudo.match(/```(?:json)?\\n([\\s\\S]*?)\\n```/) || conteudo.match(/{[\\s\\S]*}/);\n  if (jsonMatch && jsonMatch[1]) {\n    parsed = JSON.parse(jsonMatch[1]);\n  } else if (jsonMatch && jsonMatch[0]) {\n    parsed = JSON.parse(jsonMatch[0]);\n  } else {\n    parsed = JSON.parse(conteudo);\n  }\n} catch (e) {\n  status_parse = 'FALHOU_USANDO_FALLBACK';\n  observacao = 'IA n\u00e3o retornou JSON v\u00e1lido; fallback aplicado';\n  parsed = {\n    legenda_facebook: conteudo,\n    legenda_instagram: conteudo,\n    texto_telegram: conteudo,\n    hashtags: []\n  };\n}\n\nreturn {\n  json: {\n    post_id: Date.now().toString(),\n    tema: entrada.tema || 'N/A',\n    produto: entrada.produto || 'N/A',\n    legenda_facebook: parsed.legenda_facebook || parsed.facebook_legenda || parsed.facebook || conteudo,\n    legenda_instagram: parsed.legenda_instagram || parsed.instagram_legenda || parsed.instagram || conteudo,\n    texto_telegram: parsed.texto_telegram || parsed.telegram_texto || parsed.telegram || conteudo,\n    hashtags: parsed.hashtags || [],\n    image_url: entrada.image_url || '',\n    observacoes: [observacao],\n    status_parse_ia: status_parse\n  }\n};"
      },
      "id": "normalizar_saida_ia",
      "name": "NORMALIZAR_SAIDA_IA_SOCIAL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const jsonStr = JSON.stringify($json).toLowerCase();\nconst proibidos = [\n  'condfy', 'dl ignis', 'engenheiro', 'sla como termo principal', 'b2b em texto p\u00fablico', 'n8n', 'webhook', 'payload', 'garantia eterna', '100% garantido', 'sem risco', '\u00faltima chance', 'urgente demais', 'not\u00edcia sem fonte', 'sensacionalismo com trag\u00e9dia', \n  'visita t\u00e9cnica', 'visita tecnica', 'canaleta pl\u00e1stica', 'canaleta plastica', 'garantia vital\u00edcia', 'garantia vitalicia', 'hidr\u00e1ulica pura', 'hidraulica pura', 'engenheiro diogo', 'pre\u00e7o final', 'preco final', 'pre\u00e7o fechado autom\u00e1tico', 'preco fechado automatico'\n];\nconst obrigatorios = ['avalia\u00e7\u00e3o t\u00e9cnica', 'avaliacao tecnica'];\n\nconst violacoes = proibidos.filter(t => jsonStr.includes(t));\nconst possuiObrigatorio = obrigatorios.some(t => jsonStr.includes(t));\n\nlet status_killcritic = 'APROVADO';\nif (violacoes.length > 0) status_killcritic = 'REPROVADO_POR_TERMOS_PROIBIDOS';\nif (!possuiObrigatorio) status_killcritic = 'REPROVADO_POR_FALTA_DE_CTA_AVALIACAO_TECNICA';\n\nreturn {\n  json: {\n    ...$json,\n    status_killcritic,\n    violacoes\n  }\n};"
      },
