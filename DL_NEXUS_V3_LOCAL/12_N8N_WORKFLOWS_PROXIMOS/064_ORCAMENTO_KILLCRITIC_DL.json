          ]
        },
        "options": {}
      },
      "id": "supa_064_get",
      "name": "Supabase Get Markdown",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        240,
        300
      ],
      "credentials": {
        "supabaseApi": {
          "id": "SUPABASE_CREDENTIAL_ID",
          "name": "Supabase DL Nexus"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "if (!$input.all().length || !$input.all()[0].json.id) {\n  return [];\n}\nreturn $input.all();"
      },
      "id": "code_064_check",
      "name": "Check Empty",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.item.json;\nconst prompt = `\nVoc\u00ea \u00e9 o KILLCRITIC DL. Avalie o or\u00e7amento abaixo.\nVoc\u00ea DEVE bloquear o or\u00e7amento se encontrar qualquer um dos problemas abaixo:\n- Sem endere\u00e7o completo\n- Sem descri\u00e7\u00e3o de necessidade\n- Escopo insuficiente para formar pre\u00e7o\n- Rateio cond\u00f4mino solicitado mas sem \"numero_unidades\"\n- Uso da palavra \"visita t\u00e9cnica\"\n- Uso da palavra \"B2B\" para p\u00fablico\n- Promessas absolutas sem garantia t\u00e9cnica\n- Afirma\u00e7\u00f5es t\u00e9cnicas sem evid\u00eancia visual ou presencial\n\nRetorne EXATAMENTE UM JSON com a avalia\u00e7\u00e3o:\n{\n  \"decisao\": \"aprovado_para_revisao_humana\" ou \"bloqueado_pendencia\",\n  \"motivos\": [\"motivo1\", \"motivo2\"]\n}\n\nDADOS:\nPerfil: ${d.perfil_classificado}\nRateio: ${d.rateio_permitido}\nUnidades: ${d.numero_unidades}\nEndereco: ${d.endereco_completo}\nDescricao: ${d.descricao}\nMarkdown:\n${d.markdown_orcamento}\n`;\n\nreturn [{ json: { ...d, ai_prompt: prompt } }];"
      },
      "id": "code_064_prep_prompt",
      "name": "Prep Prompt KillCritic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.deepseek.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "deepseek-chat"
            },
            {
              "name": "messages",
              "value": "=[{\"role\":\"user\", \"content\": {{$json.ai_prompt}} }]"
            },
            {
              "name": "response_format",
              "value": "={\"type\": \"json_object\"}"
            }
          ]
        },
        "options": {}
      },
      "id": "http_064_deepseek",
      "name": "DeepSeek KillCritic",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        960,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "DEEPSEEK_CREDENTIAL_ID",
          "name": "DeepSeek API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const original = $input.item.json;\nconst result = JSON.parse(original.choices[0].message.content);\n\nlet novoStatus = result.decisao === 'aprovado_para_revisao_humana' \n  ? 'aprovado_para_revisao_humana' \n  : 'bloqueado_pendencia';\n\n// Vamos agregar os motivos na lista de pendencias caso bloqueado\nlet pendencias = [];\ntry {\n  pendencias = typeof original.pendencias === 'string' ? JSON.parse(original.pendencias) : (original.pendencias || []);\n} catch(e) {}\n\nif (novoStatus === 'bloqueado_pendencia' && result.motivos) {\n  pendencias = [...new Set([...pendencias, ...result.motivos])];\n}\n\nreturn [{\n  json: {\n    id: original.id,\n    status_orcamento: novoStatus,\n    status_killcritic: novoStatus,\n    pendencias: JSON.stringify(pendencias)\n  }\n}];"
      },
      "id": "code_064_parse",
      "name": "Parse Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        300
      ]
    },
    {
      "parameters": {
        "operation": "update",
        "schema": "public",
        "table": "dl_orcamentos_site_v2",
        "matchColumns": "id",
        "columns": "status_orcamento,status_killcritic,pendencias",
        "options": {}
      },
      "id": "supa_064_update",
      "name": "Supabase Update",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        1440,
