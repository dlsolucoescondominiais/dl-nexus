        "additionalFields": {
          "reply_markup": "{\"inline_keyboard\":[[{\"text\":\"Aprovar\",\"callback_data\":\"aprovar_post_{{$json.id}}\"},{\"text\":\"Revisar\",\"callback_data\":\"revisar_post_{{$json.id}}\"},{\"text\":\"Rejeitar\",\"callback_data\":\"rejeitar_post_{{$json.id}}\"}]]}"
        }
      },
      "id": "3",
      "name": "Notificar Diogo (Telegram)",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [
        650,
        300
      ]
    }
