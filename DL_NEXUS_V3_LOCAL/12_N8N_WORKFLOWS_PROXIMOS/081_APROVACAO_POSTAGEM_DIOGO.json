      "position": [
        250,
        300
      ],
      "webhookId": "socialpilot-aprovacao-in"
    },
    {
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "string": [
            {
              "name": "produto",
              "value": "={{$json.body.produto}}"
            },
            {
              "name": "titulo",
              "value": "={{$json.body.titulo}}"
            },
            {
              "name": "legenda_instagram_facebook",
              "value": "={{$json.body.legenda_instagram_facebook}}"
            },
            {
              "name": "texto_gmn",
              "value": "={{$json.body.texto_gmn}}"
            },
            {
              "name": "ideia_tiktok_reels",
              "value": "={{$json.body.ideia_tiktok_reels}}"
            },
            {
              "name": "hashtags",
              "value": "={{$json.body.hashtags}}"
            },
            {
              "name": "cta",
              "value": "={{$json.body.cta}}"
            },
            {
              "name": "status",
              "value": "aguardando_aprovacao_humana"
            }
          ]
        },
        "options": {}
      },
      "id": "2",
      "name": "Extrair e Status",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "chatId": "ID_DIOGO",
