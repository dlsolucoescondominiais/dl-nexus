      "parameters": {
        "jsCode": "// ============================================================\n// KILLCRITIC - Verificação de Termos Proibidos e Conformidade\n// DL Nexus V3 - Publicador Instagram Meta API\n// ============================================================\n\nconst body = $input.first().json.body || {};\n\nconst caption = (body.caption || '').toLowerCase();\nconst legendaOriginal = body.caption || '';\n\n// Termos explicitamente proibidos\nconst termosProibidos = [\n  'visita técnica',\n  'visita tecnica',\n  'canaleta plástica',\n  'canaleta plastica',\n  'garantia vitalícia',\n  'garantia vitalicia',\n  'engenheiro diogo',\n  'preço final',\n  'preco final'\n];\n\n// Exige presença do termo estratégico\nconst termoObrigatorio = 'avaliação técnica';\nconst termoObrigatorioAlt = 'avaliacao tecnica';\n\nconst termosEncontrados = termosProibidos.filter(termo => caption.includes(termo));\n\nconst temTermoObrigatorio =\n  caption.includes(termoObrigatorio) || caption.includes(termoObrigatorioAlt);\n\nlet statusKillcritic = 'APROVADO';\nconst motivos = [];\n\nif (termosEncontrados.length > 0) {\n  statusKillcritic = 'REPROVADO';\n  motivos.push(`Termos proibidos encontrados: [${termosEncontrados.join(', ')}]`);\n}\n\nif (!temTermoObrigatorio) {\n  statusKillcritic = 'REPROVADO';\n  motivos.push(`Termo obrigatório ausente: '${termoObrigatorio}'`);\n}\n\n// Validações adicionais de segurança\nif (!body.image_url || body.image_url.trim() === '') {\n  statusKillcritic = 'REPROVADO';\n  motivos.push('image_url ausente ou vazia');\n}\n\nif (!body.approved || String(body.approved).toLowerCase() !== 'true') {\n  statusKillcritic = 'REPROVADO';\n  motivos.push('Campo approved não está setado como true');\n}\n\nconst resultado = {\n  status_killcritic: statusKillcritic,\n  motivos_reprovacao: motivos,\n  termos_proibidos_encontrados: termosEncontrados,\n  termo_obrigatorio_presente: temTermoObrigatorio,\n  caption_auditado: legendaOriginal,\n  image_url: body.image_url || '',\n  caption: body.caption || '',\n  aprovado_pelo_usuario: body.approved,\n  timestamp_killcritic: new Date().toISOString(),\n  workflow: '081_PUBLICADOR_INSTAGRAM_META_API',\n  versao_killcritic: '1.0.0'\n};\n\nreturn [{ json: resultado }];"
      },
