      "id": "telegram_nao_aprovado",
      "name": "Telegram: N\u00e3o Aprovado",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [
        480,
        200
      ],
      "credentials": {
        "telegramApi": {
          "id": "Conta do Telegram",
          "name": "Conta do Telegram"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n// KILLCRITIC 084 - TikTok Assistido DL Nexus V3\n// Valida termos proibidos e presen\u00e7a do CTA obrigat\u00f3rio\n// \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst payload = $json.body || {};\nconst texto = JSON.stringify(payload).toLowerCase();\n\nconst termos_proibidos = [\n  'visita t\u00e9cnica', 'visita tecnica',\n  'garantia vital\u00edcia', 'garantia vitalicia',\n  'engenheiro diogo', 'pre\u00e7o final', 'preco final',\n  'pre\u00e7o fechado', 'preco fechado',\n  'canaleta pl\u00e1stica', 'canaleta plastica',\n  'hidr\u00e1ulica pura', 'hidraulica pura',\n  'pre\u00e7o fechado autom\u00e1tico', 'preco fechado automatico'\n];\n\nconst termos_obrigatorios = [\n  'avalia\u00e7\u00e3o t\u00e9cnica', 'avaliacao tecnica',\n  'tecn\u00f3logo', 'tecnologo'\n];\n\nconst violacoes = termos_proibidos.filter(t => texto.includes(t));\nconst possui_obrigatorio = termos_obrigatorios.some(t => texto.includes(t));\n\nlet status_killcritic = 'APROVADO';\nlet motivo = 'Nenhuma viola\u00e7\u00e3o detectada.';\n\nif (violacoes.length > 0) {\n  status_killcritic = 'REPROVADO_TERMOS_PROIBIDOS';\n  motivo = 'Termos proibidos encontrados: ' + violacoes.join(', ');\n}\n\nif (!possui_obrigatorio) {\n  status_killcritic = 'REPROVADO_SEM_CTA_OBRIGATORIO';\n  motivo = (motivo === 'Nenhuma viola\u00e7\u00e3o detectada.'\n    ? ''\n    : motivo + ' | ') + 'CTA obrigat\u00f3rio ausente (avalia\u00e7\u00e3o t\u00e9cnica / tecn\u00f3logo).';\n}\n\nreturn {\n  json: {\n    ...payload,\n    status_killcritic,\n    killcritic_violacoes: violacoes,\n    killcritic_motivo: motivo,\n    killcritic_timestamp: new Date().toISOString()\n  }\n};"
      },
      "id": "code_killcritic",
      "name": "Code KILLCRITIC",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.status_killcritic }}",
              "operation": "equal",
              "value2": "APROVADO"
