    {
      "parameters": {
        "chatId": "CHAT_ID_AQUI",
        "text": "={{ '\ud83d\udeab [KILLCRITIC 084] Pacote TikTok BLOQUEADO.\\n\\nMotivo: ' + $json.killcritic_motivo + '\\nViola\u00e7\u00f5es: ' + ($json.killcritic_violacoes.length > 0 ? $json.killcritic_violacoes.join(', ') : 'Nenhuma') + '\\nTimestamp: ' + $json.killcritic_timestamp }}",
        "additionalFields": {}
      },
      "id": "telegram_killcritic_bloqueado",
      "name": "Telegram: KILLCRITIC Bloqueado",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [
        960,
        200
      ],
      "credentials": {
        "telegramApi": {
          "id": "Conta do Telegram",
          "name": "Conta do Telegram"
        }
