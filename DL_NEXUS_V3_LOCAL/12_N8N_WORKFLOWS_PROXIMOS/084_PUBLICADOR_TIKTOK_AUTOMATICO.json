            },
            {
              "id": "tiktok_pacote_workflow",
              "name": "tiktok_pacote.workflow",
              "value": "={{ $json.workflow }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "set_tiktok_pacote",
      "name": "Set: salvar tiktok_pacote",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
