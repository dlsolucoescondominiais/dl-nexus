          "string": [
            {
              "value1": "={{ $json[0]?.conversion_status }}",
              "operation": "equals",
              "value2": "success"
            }
          ]
        }
      },
      "id": "node_if_already",
      "name": "IF: Já Convertido?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1120,
