    {
      "parameters": {
        "jsCode": "const doc = $input.first().json;\nfunction extractTextRun(run) {\n  if (!run.textRun) return '';\n  let text = run.textRun.content || '';\n  const style = run.textRun.textStyle || {};\n  if (style.link?.url) return `[${text.trim()}](${style.link.url})`;\n  if (style.bold && style.italic) return `***${text}***`;\n  if (style.bold) return `**${text}**`;\n  if (style.italic) return `*${text}*`;\n  if (style.weightedFontFamily?.fontFamily === 'Courier New') return `\\`${text}\\``;\n  return text;\n}\nfunction paragraphToMd(p) {\n  const style = p.paragraphStyle?.namedStyleType || 'NORMAL_TEXT';\n  const text = (p.elements||[]).map(extractTextRun).join('').trimEnd();\n  if (!text.replace(/\\s/g,'')) return '';\n  const map = { HEADING_1:'# ', HEADING_2:'## ', HEADING_3:'### ', HEADING_4:'#### ', HEADING_5:'##### ', HEADING_6:'###### ' };\n  return (map[style]||'') + text;\n}\nfunction tableToMd(table) {\n  try {\n    const rows = (table.tableRows||[]).map(row => '| ' + (row.tableCells||[]).map(cell => (cell.content||[]).map(c => (c.paragraph?.elements||[]).map(extractTextRun).join('')).join(' ').trim().replace(/\\n/g,' ')).join(' | ') + ' |');\n    const cols = (table.tableRows?.[0]?.tableCells||[]).length;\n    const sep = '| ' + Array(cols).fill('---').join(' | ') + ' |';\n    return [rows[0], sep, ...rows.slice(1)].join('\\n');\n  } catch(e) { return '> TABELA ORIGINAL — conversão parcial'; }\n}\nconst content = doc.body?.content || [];\nconst lines = [];\nlet lastEmpty = false;\nfor (const block of content) {\n  if (block.paragraph) {\n    const p = block.paragraph;\n    const line = p.bullet ? `${'  '.repeat(p.bullet.nestingLevel||0)}- ${(p.elements||[]).map(extractTextRun).join('').trimEnd()}` : paragraphToMd(p);\n    if (!line) { if (!lastEmpty) lines.push(''); lastEmpty = true; } else { lines.push(line); lastEmpty = false; }\n  }\n  if (block.table) { lines.push(''); lines.push(tableToMd(block.table)); lines.push(''); lastEmpty = false; }\n}\nconst raw = lines.join('\\n');\nconst md = raw.replace(/^\\s*\\d+\\s*$/gm,'').replace(/ {2,}/g,' ').replace(/\\n{3,}/g,'\\n\\n').trim();\nconst prev = $('Code: Validar MIME + Calcular Hash').first().json;\nreturn [{ json: { markdown_content: md, char_count: md.length, line_count: md.split('\\n').length, document_title: doc.title || prev.document_title, source_file_id: prev.source_file_id, source_file_name: prev.source_file_name, google_doc_temp_id: $('Drive API: Copiar PDF como Google Docs').first().json.id, ocr_used: prev.use_ocr, output_folder_id: prev.output_folder_id, file_hash: prev.file_hash } }];"
      },
      "id": "node_convert_md",
      "name": "Code: Converter Docs → Markdown",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        420
      ]
    },
