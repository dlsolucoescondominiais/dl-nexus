      "typeVersion": 2,
      "position": [
        240,
        300
      ],
      "webhookId": "dl-util-pdf-to-markdown"
    },
    {
      "parameters": {
        "operation": "get",
        "fileId": {
          "__rl": true,
          "mode": "expression",
          "value": "={{ $json.body.drive_file_id }}"
        },
        "options": {
          "fields": "id,name,mimeType,modifiedTime,size"
        }
      },
      "id": "node_get_file",
      "name": "Drive: Buscar Metadados do PDF",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        460,
        300
      ],
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "GOOGLE_DRIVE_CREDENTIAL_ID",
          "name": "DL Nexus — Google Drive OAuth2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst file = $input.first().json;\nconst allowedMimes = ['application/pdf','image/jpeg','image/png','image/tiff'];\nconst mimeType = file.mimeType || '';\nif (!allowedMimes.includes(mimeType)) throw new Error(`MIME type inválido: ${mimeType}`);\nconst useOcr = mimeType !== 'application/pdf' || ($('Webhook (Receber PDF ID)').first().json.body?.use_ocr === true);\nconst hashInput = `${file.id}::${file.modifiedTime || ''}`;\nconst fileHash = crypto.createHash('sha256').update(hashInput).digest('hex');\nreturn [{ json: { source_file_id: file.id, source_file_name: file.name, mime_type: mimeType, file_hash: fileHash, use_ocr: useOcr, ocr_language: 'pt-BR', output_folder_id: $('Webhook (Receber PDF ID)').first().json.body?.output_folder_id || 'FOLDER_ID_06_RAG_MARKDOWN', document_title: file.name.replace(/\\.pdf$/i, ''), drive_file_url: `https://drive.google.com/file/d/${file.id}/view` } }];"
      },
      "id": "node_validate",
      "name": "Code: Validar MIME + Calcular Hash",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, markdown_file_id, conversion_status FROM dl_nexus_pdf_to_markdown WHERE file_hash = '{{ $json.file_hash }}' LIMIT 1;"
      },
      "id": "node_check_idem",
      "name": "Supabase: Checar Idempotência",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.1,
      "position": [
        900,
        300
