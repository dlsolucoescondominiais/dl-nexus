      "id": "node_read_doc",
      "name": "Docs API: Ler Estrutura do Documento",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1780,
        420
      ],
      "credentials": {
        "oAuth2Api": {
