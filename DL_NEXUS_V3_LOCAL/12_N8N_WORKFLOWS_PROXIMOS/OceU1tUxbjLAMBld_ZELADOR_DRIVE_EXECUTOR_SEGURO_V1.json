        "query": "SELECT file_id, current_folder_id, pasta_destino_sugerida as pasta_destino_id, acao_sugerida as acao_aprovada, status, precisa_revisao_humana FROM drive_zelador_inventory WHERE status = 'aprovado_para_mover' LIMIT 50;",
