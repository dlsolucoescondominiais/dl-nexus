{
  "name": "SOCIAL_VERIFICADOR_TOKEN_META",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cron",
              "expression": "0 7 * * 1"
            }
          ]
        }
      },
      "id": "trigger_semanal_segunda_7h",
      "name": "Trigger Semanal (Segunda 7h)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://graph.facebook.com/v25.0/{{$env.META_FACEBOOK_PAGE_ID || '100166804716824'}}?fields=id,name,username,link,instagram_business_account",
        "method": "GET",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + $env.META_PAGE_ACCESS_TOKEN_DL }}"
            }
          ]
        },
        "sendQuery": true,
        "specifyQuery": "json",
        "jsonQuery": "={\n  \"appsecret_proof\": \"{{ $env.META_APP_SECRET ? $evaluateExpression('crypto.createHmac(\\'sha256\\', $env.META_APP_SECRET).update($env.META_PAGE_ACCESS_TOKEN_DL).digest(\\'hex\\')') : '' }}\"\n}"
      },
      "id": "meta_token_check",
      "name": "Verificar Token Meta",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        300,
        300
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ !!$json.error }}",
              "value2": true
            }
          ]
        }
      },
      "id": "if_token_failed",
      "name": "Token Invalido?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        500,
        300
      ]
    },
    {
      "parameters": {
        "chatId": "YOUR_TELEGRAM_CHAT_ID",
        "text": "=⚠️ *Alerta Crítico: Token Meta Expirado (DL)*\n\nO *token de sistema/longa duração com verificação preventiva* do Meta falhou na validação de rotina.\n\n*Erro retornado:* `{{ JSON.stringify($json.error) }}`\n\n_Ação necessária: Reautorizar a conta Meta e atualizar a variável META_PAGE_ACCESS_TOKEN_DL no arquivo .env._"
      },
      "id": "telegram_token_alert",
      "name": "Alerta Telegram Token Meta",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [
        720,
        200
      ],
      "credentials": {
        "telegramApi": {
          "id": "telegram_cred_id",
          "name": "Telegram Bot Account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { status: \"ok\", mensagem: \"Token verificado e ativo.\" } }];"
      },
      "id": "token_ok_log",
      "name": "Log Token Ok",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        400
      ]
    }
  ],
  "connections": {
    "Trigger Semanal (Segunda 7h)": {
      "main": [
        [
          {
            "node": "Verificar Token Meta",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Verificar Token Meta": {
      "main": [
        [
          {
            "node": "Token Invalido?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Token Invalido?": {
      "main": [
        [
          {
            "node": "Alerta Telegram Token Meta",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Log Token Ok",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  }
}