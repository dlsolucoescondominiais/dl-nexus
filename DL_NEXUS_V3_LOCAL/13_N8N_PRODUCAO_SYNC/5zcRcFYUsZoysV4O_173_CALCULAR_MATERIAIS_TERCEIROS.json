        0,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nfor (let i = 0; i < items.length; i++) {\n  const payload = items[i].json;\n  \n  if (!payload.materiais || !Array.isArray(payload.materiais) || payload.materiais.length === 0) {\n    items[i].json.materiais_a_parte = true;\n    items[i].json.mensagem_materiais = \"Materiais a serem faturados à parte mediante Avaliação Técnica ou repassados ao condomínio.\";\n    items[i].json.custo_materiais_total = 0;\n  } else {\n    items[i].json.materiais_a_parte = false;\n    let totalMaterial = 0;\n    for (let mat of payload.materiais) {\n       totalMaterial += (mat.quantidade || 0) * (mat.preco_unitario || 0);\n    }\n    items[i].json.custo_materiais_total = totalMaterial;\n  }\n}\nreturn items;"
      },
      "id": "code-calcularMateriais173DlNexus20260527",
