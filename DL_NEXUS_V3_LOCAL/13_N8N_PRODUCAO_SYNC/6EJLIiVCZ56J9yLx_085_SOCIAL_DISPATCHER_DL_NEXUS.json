        "jsCode": "// ============================================================\n// AGREGADOR DE RESULTADOS DE DISPATCH\n// Consolida respostas de todos os canais\n// ============================================================\n\n// Coleta os itens anteriores de todos os branches\nconst items = $input.all();\n\nconst canaisDisparados = [\n  'Instagram (081)',\n  'Facebook (082)',\n  'Google Business (083)',\n  'TikTok Assistido (084)'\n];\n\nconst timestamp = new Date().toISOString();\n\nreturn [{\n  json: {\n    status: 'DISPATCH_CONCLUIDO',\n    canais_disparados: canaisDisparados,\n    total_canais: canaisDisparados.length,\n    timestamp_conclusao: timestamp,\n    workflow: '085_SOCIAL_DISPATCHER_DL_NEXUS',\n    mensagem: `✅ Dispatch concluído em ${canaisDisparados.length} canais às ${timestamp}`\n  }\n}];"
