    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// ============================================================\n// VALIDADOR DE PAYLOAD - 085_SOCIAL_DISPATCHER_DL_NEXUS\n// Verifica campos obrigatórios antes de disparar para os canais\n// ============================================================\n\nconst body = $input.item.json.body || $input.item.json;\n\nconst camposObrigatorios = ['tema', 'texto', 'canal_destino'];\nconst camposFaltando = [];\n\nfor (const campo of camposObrigatorios) {\n  if (!body[campo] || String(body[campo]).trim() === '') {\n    camposFaltando.push(campo);\n  }\n}\n\nif (camposFaltando.length > 0) {\n  throw new Error(\n    `Payload inválido. Campos obrigatórios ausentes: ${camposFaltando.join(', ')}. ` +\n    `Payload recebido: ${JSON.stringify(body)}`\n  );\n}\n\n// Normaliza canal_destino para array\nlet canais = body.canal_destino;\nif (typeof canais === 'string') {\n  canais = canais.split(',').map(c => c.trim().toLowerCase());\n} else if (!Array.isArray(canais)) {\n  canais = ['instagram', 'facebook', 'google_business', 'tiktok'];\n}\n\n// Monta payload enriquecido\nconst payloadValidado = {\n  ...body,\n  approved: true,\n  canal_destino: canais,\n  dispatch_timestamp: new Date().toISOString(),\n  workflow_origem: '085_SOCIAL_DISPATCHER_DL_NEXUS',\n  versao: 'DL_NEXUS_V3'\n};\n\nreturn [{ json: payloadValidado }];"
      },
