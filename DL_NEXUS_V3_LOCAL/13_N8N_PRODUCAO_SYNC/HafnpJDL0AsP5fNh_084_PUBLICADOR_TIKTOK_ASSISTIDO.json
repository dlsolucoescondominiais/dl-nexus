    {
      "parameters": {
        "jsCode": "// ─────────────────────────────────────────────\n// KILLCRITIC 084 - TikTok Assistido DL Nexus V3\n// Valida termos proibidos e presença do CTA obrigatório\n// ─────────────────────────────────────────────\nconst payload = $json.body || {};\nconst texto = JSON.stringify(payload).toLowerCase();\n\nconst termos_proibidos = [\n  'visita técnica', 'visita tecnica',\n  'garantia vitalícia', 'garantia vitalicia',\n  'engenheiro diogo', 'preço final', 'preco final',\n  'preço fechado', 'preco fechado',\n  'canaleta plástica', 'canaleta plastica',\n  'hidráulica pura', 'hidraulica pura',\n  'preço fechado automático', 'preco fechado automatico'\n];\n\nconst termos_obrigatorios = [\n  'avaliação técnica', 'avaliacao tecnica',\n  'tecnólogo', 'tecnologo'\n];\n\nconst violacoes = termos_proibidos.filter(t => texto.includes(t));\nconst possui_obrigatorio = termos_obrigatorios.some(t => texto.includes(t));\n\nlet status_killcritic = 'APROVADO';\nlet motivo = 'Nenhuma violação detectada.';\n\nif (violacoes.length > 0) {\n  status_killcritic = 'REPROVADO_TERMOS_PROIBIDOS';\n  motivo = 'Termos proibidos encontrados: ' + violacoes.join(', ');\n}\n\nif (!possui_obrigatorio) {\n  status_killcritic = 'REPROVADO_SEM_CTA_OBRIGATORIO';\n  motivo = (motivo === 'Nenhuma violação detectada.'\n    ? ''\n    : motivo + ' | ') + 'CTA obrigatório ausente (avaliação técnica / tecnólogo).';\n}\n\nreturn {\n  json: {\n    ...payload,\n    status_killcritic,\n    killcritic_violacoes: violacoes,\n    killcritic_motivo: motivo,\n    killcritic_timestamp: new Date().toISOString()\n  }\n};"
      },
      "id": "code_killcritic",
      "name": "Code KILLCRITIC",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.status_killcritic }}",
              "operation": "equal",
              "value2": "APROVADO"
            }
          ]
        }
      },
      "id": "if_killcritic",
      "name": "IF: KILLCRITIC aprovado",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        720,
        0
      ]
    },
