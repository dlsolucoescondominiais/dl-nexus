        "chatId": "CHAT_ID_AQUI",
        "text": "={{ '\ud83d\udce6 [084] PACOTE TIKTOK GERADO - DL SOLU\u00c7\u00d5ES\\n\\n\ud83d\udccc Tema: ' + $json['tiktok_pacote.tema'] + '\\n\ud83d\udee0\ufe0f Produto: ' + $json['tiktok_pacote.produto'] + '\\n\\n\ud83c\udfac ROTEIRO:\\n' + $json['tiktok_pacote.roteiro'] + '\\n\\n\u270d\ufe0f LEGENDA SUGERIDA:\\n' + $json['tiktok_pacote.legenda_sugerida'] + '\\n\\n\ud83c\udff7\ufe0f HASHTAGS:\\n' + $json['tiktok_pacote.hashtags'] + '\\n\\n\ud83d\udccb INSTRU\u00c7\u00c3O:\\n' + $json['tiktok_pacote.instrucao'] + '\\n\\n\u23f0 Gerado em: ' + $json['tiktok_pacote.pacote_gerado_em'] + '\\n\\n\u26a0\ufe0f Este workflow N\u00c3O publica automaticamente. Siga o roteiro e poste manualmente no TikTok.' }}",
