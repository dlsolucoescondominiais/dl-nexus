    {
      "parameters": {
        "chatId": "CHAT_ID_AQUI",
        "text": "={{ '\u26d4 [084] Requisi\u00e7\u00e3o bloqueada: campo approved n\u00e3o \u00e9 true.\\nPayload recebido: ' + JSON.stringify($json.body) }}",
        "additionalFields": {}
      },
      "id": "telegram_nao_aprovado",
      "name": "Telegram: N\u00e3o Aprovado",
      "type": "n8n-nodes-base.telegram",
