      "parameters": {
        "jsCode": "let data;\ntry {\n  data = JSON.parse($input.item.json.choices[0].message.content);\n} catch (e) {\n  data = { task: \"Indefinido\", location: \"Indefinido\", date: new Date().toISOString().split('T')[0], time: \"09:00\" };\n}\n\n// Calcula hora final (+2h)\nlet start = `${data.date}T${data.time}:00`;\nreturn [{ json: { ...data, start_time: start } }];"
      },
