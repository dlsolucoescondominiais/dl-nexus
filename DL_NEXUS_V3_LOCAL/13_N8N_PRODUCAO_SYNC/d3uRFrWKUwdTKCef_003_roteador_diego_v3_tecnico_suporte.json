    {
      "parameters": {
        "method": "POST",
        "url": "https://n8n.dlsolucoescondominiais.com.br/webhook/dl-especialistas",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"origem\": \"diego-suporte-tecnico\",\n  \"lead_id\": \"{{ $json.lead_id }}\",\n  \"nome\": \"{{ $json.nome }}\",\n  \"telefone\": \"{{ $json.telefone }}\",\n  \"email\": \"{{ $json.email }}\",\n  \"condominio\": \"{{ $json.condominio }}\",\n  \"tipo_suporte\": \"{{ $json.tipo_suporte }}\",\n  \"servico\": \"{{ $json.servico }}\",\n  \"urgencia\": \"{{ $json.urgencia }}\",\n  \"mensagem\": \"{{ $json.mensagem }}\",\n  \"timestamp\": \"{{ $json.timestamp }}\",\n  \"acao_solicitada\": \"avaliacao_tecnica\"\n}",
        "options": {
          "timeout": 15000
        }
      },
