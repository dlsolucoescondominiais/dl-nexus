    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"status\": \"sucesso\",\n  \"mensagem\": \"Suporte técnico DL acionado com sucesso.\",\n  \"lead_id\": \"{{ $json.lead_id || 'registrado' }}\",\n  \"tipo_suporte\": \"{{ $json.tipo_suporte || 'geral' }}\",\n  \"proximo_passo\": \"Avaliação Técnica será agendada. O Tecnólogo responsável entrará em contato.\"\n}",
        "options": {}
