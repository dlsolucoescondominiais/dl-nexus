    {
      "parameters": {
        "jsCode": "const evento = $node['NORMALIZAR_EVENTO_META'].json;\nconst buscaResult = $input.item.json;\nlet conversa = null;\nlet isNova = true;\nlet historico_resumido = 'Primeira mensagem da conversa.';\nlet dados_coletados = {};\nlet etapa_funil = 'recepcao';\nif (Array.isArray(buscaResult) && buscaResult.length > 0) {\n  conversa = buscaResult[0];\n  isNova = false;\n  etapa_funil = conversa.etapa_funil || 'recepcao';\n  dados_coletados = {\n    nome_condominio: conversa.nome_condominio_empresa || null,\n    bairro: conversa.bairro || null,\n    cidade: conversa.cidade || null,\n    tipo_cliente: conversa.tipo_cliente || null,\n    servico: conversa.servico_interesse || null,\n    telefone: conversa.telefone || null,\n    email: conversa.email || null,\n    urgencia: conversa.urgencia || null\n  };\n} else if (buscaResult && buscaResult.id) {\n  conversa = buscaResult;\n  isNova = false;\n  etapa_funil = conversa.etapa_funil || 'recepcao';\n  dados_coletados = {\n    nome_condominio: conversa.nome_condominio_empresa || null,\n    bairro: conversa.bairro || null,\n    cidade: conversa.cidade || null,\n    tipo_cliente: conversa.tipo_cliente || null,\n    servico: conversa.servico_interesse || null\n  };\n}\nreturn [{ json: {\n  ...evento,\n  conversa_id: conversa ? conversa.id : null,\n  conversa_existente: !isNova,\n  etapa_funil,\n  dados_coletados,\n  historico_resumido,\n  ultimo_resumo: conversa ? conversa.ultimo_resumo : null\n}}];"
