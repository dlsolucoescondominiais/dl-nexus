    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\nconst evento = $node['PROCESSAR_CONVERSA'].json || item;\nconst historicoBruto = item;\nlet historico = 'Primeira mensagem.';\nif (Array.isArray(historicoBruto) && historicoBruto.length > 0) {\n  historico = historicoBruto.map(m => (m.direction === 'inbound' ? 'Lead: ' : 'Aninha: ') + (m.texto || '(sem texto)')).reverse().join('\\n');\n} else if (evento.ultimo_resumo) {\n  historico = evento.ultimo_resumo;\n}\nconst dados = JSON.stringify(evento.dados_coletados || {});\nconst etapa = evento.etapa_funil || 'recepcao';\nconst canal = evento.canal_origem || 'desconhecido';\nconst mensagem = evento.texto_mensagem || '';\nconst prompt = `Você é Aninha, assistente de atendimento e qualificação da DL Soluções Condominiais.\\nVocê atende leads vindos do Instagram Direct e Facebook Messenger.\\nSeu objetivo é entender a necessidade, qualificar o perfil, gerar confiança e encaminhar para Avaliação Técnica quando o lead for compatível.\\n\\nPúblico atendido: condomínios, administradoras, escolas/colégios, empresas, restaurantes, lanchonetes, operações comerciais.\\nA DL NÃO atende serviço residencial comum.\\n\\nRegras de linguagem:\\n- SEMPRE use Avaliação Técnica. NUNCA use visita técnica.\\n- NUNCA use Condfy. NUNCA use DL Ignis.\\n- NUNCA chame Diogo de engenheiro. Use Tecnólogo Responsável somente se necessário.\\n- NUNCA prometa preço final sem Avaliação Técnica.\\n- NUNCA invente certificações.\\n- NUNCA use termos internos: n8n, webhook, payload, API, CRM, automação interna, B2B.\\n\\nHistorico:\\n${historico}\\n\\nMensagem atual do lead:\\n${mensagem}\\n\\nDados já coletados: ${dados}\\n\\nResponda como Aninha.`;\nreturn [{ json: {\n  ...evento,\n  prompt,\n  historico\n}}];"
      },
