    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body || $input.item.json;\nconst entries = body.entry || [];\nconst results = [];\nfor (const entry of entries) {\n  const messaging = entry.messaging || [];\n  const objectType = body.object;\n  for (const event of messaging) {\n    const isInstagram = objectType === 'instagram';\n    const canal_origem = isInstagram ? 'instagram_direct' : 'facebook_messenger';\n    const sender_id = String(event.sender?.id || '');\n    const recipient_id = String(event.recipient?.id || '');\n    const message = event.message || {};\n    const is_echo = message.is_echo === true;\n    if (is_echo) continue;\n    if (sender_id === '100063696635033' || sender_id === '3136866194') continue;\n    const message_id = message.mid || '';\n    const texto_mensagem = message.text || '';\n    const timestamp = event.timestamp || Date.now();\n    const attachments = message.attachments || [];\n    const has_attachment = attachments.length > 0;\n    const attachment_type = has_attachment ? attachments[0].type : '';\n    const attachment_url = has_attachment ? (attachments[0].payload?.url || '') : '';\n    if (!texto_mensagem && !has_attachment) continue;\n    results.push({ json: {\n      canal_origem, platform: isInstagram ? 'instagram' : 'facebook',\n      sender_id, recipient_id,\n      page_id: isInstagram ? '' : String(entry.id),\n      instagram_business_account_id: isInstagram ? String(entry.id) : '',\n      message_id, texto_mensagem, timestamp,\n      nome_contato: '', username: '',\n      raw_event: event, is_echo: false,\n      has_attachment, attachment_type, attachment_url,\n      dry_run: true\n    }});\n  }\n}\nif (results.length === 0) {\n  return [{ json: { tipo: 'meta_evento_nao_mapeado', raw: body, ignorar: true } }];\n}\nreturn results;"
      },
