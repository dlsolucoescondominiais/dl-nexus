      "parameters": {
        "jsCode": "const query = $input.item.json.query || {};\nconst mode = query['hub.mode'];\nconst token = query['hub.verify_token'];\nconst challenge = query['hub.challenge'];\nconst VERIFY_TOKEN = 'dl_sdr_social_2026_verify';\nif (mode === 'subscribe' && token === VERIFY_TOKEN) {\n  return [{ json: { challenge: String(challenge), valid: true } }];\n}\nreturn [{ json: { challenge: '', valid: false, error: 'Token invalido' } }];"
