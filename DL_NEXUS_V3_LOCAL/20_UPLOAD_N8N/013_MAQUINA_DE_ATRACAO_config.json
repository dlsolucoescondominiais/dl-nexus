      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.1,
      "position": [ 400, 300 ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT media_url FROM conteudos_marketing WHERE id = {{$('Salvar Postgres').item.json.id}} LIMIT 1;"
