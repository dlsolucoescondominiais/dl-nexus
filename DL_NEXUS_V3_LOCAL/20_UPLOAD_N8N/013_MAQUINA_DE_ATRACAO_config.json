      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.1,
      "position": [ 600, 300 ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            { "value1": "={{ $('Gerar Conteúdo').item.json.text }}", "operation": "notContains", "value2": "visita técnica" },
            { "value1": "={{ $('Gerar Conteúdo').item.json.text }}", "operation": "notContains", "value2": "Condfy" },
            { "value1": "={{ $('Gerar Conteúdo').item.json.text }}", "operation": "notContains", "value2": "engenheiro" },
            { "value1": "={{ $('Gerar Conteúdo').item.json.text }}", "operation": "notContains", "value2": "preço final" },
            { "value1": "={{ $('Gerar Conteúdo').item.json.text }}", "operation": "notContains", "value2": "residencial" },
            { "value1": "={{ $('Gerar Conteúdo').item.json.text }}", "operation": "contains", "value2": "https://dlsolucoescondominiais.com" },
            { "value1": "={{ $('Gerar Conteúdo').item.json.text }}", "operation": "contains", "value2": "https://wa.me/5521964742458" }
