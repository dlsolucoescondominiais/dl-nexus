# ========================================================
# CÉREBRO ANTIGRAVITY - DL SOLUÇÕES CONDOMINIAIS
# ========================================================

# 1. Chaves de IA
GEMINI_API_KEY=sua-chave-gemini-aqui
OPENAI_API_KEY=sua-chave-openai-aqui

# 2. Segurança de JWT (Vem do Supabase: Settings -> API -> JWT Secret)
# Isso impede que hackers acionem nossos agentes de energia solar para gastar tokens
SUPABASE_JWT_SECRET=sua-chave-jwt-gerada-no-supabase

# 3. Comunicação Omnichannel (Callbacks para o Orquestrador n8n)
N8N_WEBHOOK_URL=https://n8n.dlsolucoescondominiais.com.br/webhook/dl-automacao-sindicos
N8N_API_KEY=a-mesma-chave-header-auth-usada-no-n8n-X-DL-API-KEY

# 4. Acesso ao Google (Para o Arquivista/Zelador)
# Opcional se for rodar via service account
GOOGLE_CREDENTIALS_PATH=./credentials_drive.json

# 5. Configurações da Meta/WhatsApp (App para integração com N8N)
META_VERIFY_TOKEN=token-seguro-para-verificacao-webhook
META_ACCESS_TOKEN=seu-token-de-acesso-api-whatsapp
META_PHONE_NUMBER_ID=id-do-telefone-no-whatsapp-business
WHATSAPP_BUSINESS_ACCOUNT_ID=id-da-conta-whatsapp-business

# Webhook interno do N8N onde as mensagens do Meta serão processadas (via rede interna docker)
N8N_WEBHOOK_META=http://n8n:5678/webhook/dl-receptor
