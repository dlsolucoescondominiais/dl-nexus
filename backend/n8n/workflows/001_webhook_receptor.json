          }
        ],
        [
          {
            "node": "Resposta Comercial (GPT-4o)",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Resposta Comercial (GPT-4o)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Resposta Técnica (Sonnet)": {
