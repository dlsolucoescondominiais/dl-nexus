          {
            "node": "Roteamento Otimizado",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Google Gemini": {
      "ai_languageModel": [
        [
          {
            "node": "Triagem Avançada (Gemini Flash)",
            "type": "ai_languageModel",
            "index": 0
          }
        ]
      ]
    },
    "Roteamento Otimizado": {
      "main": [
        [
          {
