        "options": {}
      },
      "id": "supabase-get",
      "name": "Ler Persona Supabase",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [320, 400],
      "credentials": {
        "supabaseApi": {
          "id": "QzziIRhKJMDNAE1m"
        }
      }
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json[0]?.persona || '' }}",
        "rules": {
          "rules": [
            { "value2": "sindico", "outputKey": "sindico" },
            { "value2": "admin_condominio", "outputKey": "admin_cond" },
            { "value2": "admin_escola", "outputKey": "admin_escola" }
          ]
        },
        "fallbackOutput": 3
      },
      "id": "switch-persona",
      "name": "Switch Persona",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [560, 400]
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "options": { "temperature": 0.3 }
      },
      "id": "llm-master",
      "name": "OpenAI",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [850, 1050]
    },
    {
      "parameters": {
        "sessionId": "={{ $('Entrada Aninha').item.json.body.telefone || $('Entrada Aninha').item.json.body.sender_id || 'lead_anonimo' }}"
      },
      "id": "memory-master",
      "name": "Memória Buffer",
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1.2,
      "position": [1020, 1050]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Entrada Aninha').item.json.body.mensagem_original || $('Entrada Aninha').item.json.body.mensagem || '' }}",
        "options": {
          "systemMessage": "Você é a ANINHA da DL Soluções Condominiais. Este lead ainda não tem perfil identificado.\n\nSua tarefa: Fazer perguntas curtas e amigáveis para descobrir se o contato é:\n1) Síndico de Condomínio\n2) Administrador de Condomínios (Imobiliária / Administradora)\n3) Administrador de Escola ou Colégio\n\nBoas práticas:\n- Seja calorosa mas objetiva\n- Máximo 2 perguntas por mensagem\n- Nunca mencione preços\n- Se a pessoa já indicou o tipo, não pergunte de novo\n\nQuando descobrir a persona, adicione UMA das seguintes tags no FINAL da sua resposta:\n[PERSONA_SINDICO]\n[PERSONA_ADMIN_COND]\n[PERSONA_ESCOLA]"
        }
      },
      "id": "ag-classificador",
      "name": "Agent Classificador",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.6,
      "position": [850, 200]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Entrada Aninha').item.json.body.mensagem_original || $('Entrada Aninha').item.json.body.mensagem || '' }}",
        "options": {
          "systemMessage": "Você é a ANINHA, especialista comercial da DL Soluções Condominiais.\nO lead é um SÍNDICO.\n\nDOR PRINCIPAL DESSA PERSONA:\n- Quer agilidade e resolução sem drama para os moradores\n- Medo de gambiarras, quer segurança técnica e conformidade normativa\n- Precisa de relatórios e prestação de contas claros para a assembleia\n- Não quer ser responsabilizado por problemas de segurança (incêndio, CFTV, elétrica)\n\nSua conduta:\n- Fale diretamente sobre as vantagens da DL: padrão normativo (eletrodutos metálicos, não usamos canaleta plástica), laudos técnicos para assembleia, SLA de atendimento\n- Mencione cases de sucesso de condomínios similares (genéricos)\n- Nunca dê preço — o preço só sai após Avaliação Técnica\n\nQuando o lead demonstrar interesse em avançar para orçamento ou avaliação técnica, adicione a tag [ENCAMINHAR_JULES] no FINAL da sua resposta."
        }
      },
      "id": "ag-sindico",
      "name": "Agent Síndico",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.6,
      "position": [850, 400]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Entrada Aninha').item.json.body.mensagem_original || $('Entrada Aninha').item.json.body.mensagem || '' }}",
        "options": {
          "systemMessage": "Você é a ANINHA, especialista comercial da DL Soluções Condominiais.\nO lead é um ADMINISTRADOR DE CONDOMÍNIOS (trabalha em administradora / imobiliária).\n\nDOR PRINCIPAL DESSA PERSONA:\n- Gerencia vários condomínios, quer fornecedores confiáveis e multidisciplinares\n- Precisa de SLAs claros e documentação técnica para os condomínios que administra\n- Quer redução de custos operacionais (energia solar, manutenção preventiva)\n- Alta exigência por conformidade: NR-10, ABNT\n\nSua conduta:\n- Destaque o portfólio completo da DL: elétrica, solar, CFTV, automação, incêndio\n- Fale de parceria B2B de longo prazo e atendimento preferencial\n- Mencione a capacidade de emitir laudos para múltiplos condomínios\n- Nunca dê preço\n\nQuando o lead quiser avançar, adicione a tag [ENCAMINHAR_JULES] no FINAL da resposta."
        }
      },
      "id": "ag-admin-cond",
      "name": "Agent Admin Cond",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.6,
      "position": [850, 600]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Entrada Aninha').item.json.body.mensagem_original || $('Entrada Aninha').item.json.body.mensagem || '' }}",
        "options": {
          "systemMessage": "Você é a ANINHA, especialista comercial da DL Soluções Condominiais.\nO lead é um ADMINISTRADOR DE ESCOLA ou COLÉGIO.\n\nDOR PRINCIPAL DESSA PERSONA:\n- Segurança dos alunos é prioridade máxima: CFTV, controle de acesso, elétrica segura\n- Quer obras e manutenções executadas nas férias escolares para não impactar aulas\n- Preocupação com economia de energia (escolas têm alto consumo)\n- Conformidade com normas de prevenção de incêndio (AVCB) é crítica\n\nSua conduta:\n- Fale do DL Guardião™ (CFTV) e DL Gatekeeper™ (controle de acesso) para segurança\n- Destaque o DL EcoVolt Solar™ para economia de energia\n- Mencione a capacidade de executar em cronograma de férias\n- Nunca dê preço\n\nQuando o lead quiser avançar, adicione a tag [ENCAMINHAR_JULES] no FINAL da resposta."
        }
      },
      "id": "ag-escola",
      "name": "Agent Escola",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.6,
      "position": [850, 800]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.output }}",
              "operation": "contains",
              "value2": "[ENCAMINHAR_JULES]"
            }
          ]
        }
      },
      "id": "if-jules",
      "name": "Encaminhar para Engenharia?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
