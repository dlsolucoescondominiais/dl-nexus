            {
              "column": "status",
              "value": "Aguardando Avaliacao Tecnica"
            },
            {
              "column": "historico_coleta",
              "value": "={{ $json.output }}"
            }
          ]
        }
      },
      "id": "supa-jules-final",
      "name": "Atualiza Supabase - Status Final",
