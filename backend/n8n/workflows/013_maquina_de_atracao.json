{
  "name": "013 - Máquina de Atração (Redes Sociais)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 10 * * 1"
            }
          ]
        }
      },
      "id": "e0b5c1a8-9d4f-4b3a-8c2e-1f5d6a7b8c9d",
      "name": "Cron (Segunda 10h)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        200,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const topics = [\n  \"Controle de bombas\",\n  \"Controle de cisternas\",\n  \"Controle de boias\",\n  \"Automação de recalque\",\n  \"Alarme de nível\",\n  \"Falha de bomba\",\n  \"Rodízio de bombas\",\n  \"Painel de comando\",\n  \"Proteção elétrica de bomba\",\n  \"Relatório de funcionamento\"\n];\n\nconst index = Math.floor(Math.random() * topics.length);\nconst selectedTopic = topics[index];\n\nreturn [\n  {\n    json: {\n      tema: selectedTopic\n    }\n  }\n];"
      },
      "id": "code-node-topics-1234",
      "name": "Selecionar Tema Automático",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.OPENAI_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "gpt-4o-mini"
            },
            {
              "name": "messages",
              "value": "={{ [ { \"role\": \"system\", \"content\": \"Você é o Diretor Técnico da DL Soluções Condominiais. Escreva um post curto e direto focado em síndicos, sobre a importância de implementar \" + $json.tema + \" no condomínio. Use linguagem profissional. Retorne APENAS o texto do post.\" } ] }}"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-e5f6-7a8b-9c0d-1e2f3a4b5c6d",
      "name": "Gerar Copy (OpenAI)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        640,
        300
      ]
    },
    {
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "string": [
            {
              "name": "tipo",
              "value": "educativo"
            },
            {
              "name": "problema",
              "value": "automacao"
            },
            {
              "name": "copy_gerada",
              "value": "={{ $json.choices[0].message.content }}"
            },
            {
              "name": "status",
              "value": "pendente_aprovacao"
            }
          ]
        },
        "options": {}
      },
      "id": "set-node-fields-5678",
      "name": "Mapear Campos DB",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        860,
        300
      ]
    },
    {
      "parameters": {
        "operation": "insert",
        "schema": "public",
        "table": "conteudos_marketing",
        "columns": "tipo, problema, copy_gerada, status",
        "dataMode": "autoMapInputData",
        "options": {}
      },
      "id": "f5e4d3c2-b1a0-9f8e-7d6c-5b4a3c2d1e0f",
      "name": "Salvar Pendente Aprovação",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.1,
      "position": [
        1080,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "supabase-db",
          "name": "Supabase"
        }
      }
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "dl-aprovar-post",
        "options": {}
      },
      "id": "1a2b3c4d-5e6f-7a8b-9c0d-e1f2a3b4c5d6",
      "name": "Webhook (dl-aprovar-post)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        200,
        500
      ],
      "webhookId": "dl-aprovar-post"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://graph.facebook.com/v19.0/me/feed",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "message",
              "value": "={{ $json.body.copy_aprovada }}"
            },
            {
              "name": "link",
              "value": "={{ $json.body.imagem_url }}"
            },
            {
              "name": "access_token",
              "value": "={{ $env.META_ACCESS_TOKEN }}"
            }
          ]
        },
        "options": {}
      },
      "id": "6d5c4b3a-2f1e-0d9c-8b7a-6f5e4d3c2b1a",
      "name": "Postar na Meta",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        420,
        500
      ]
    },
    {
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "string": [
            {
              "name": "id",
              "value": "={{ $node[\"Webhook (dl-aprovar-post)\"].json.body.post_id }}"
            },
            {
              "name": "status",
              "value": "publicado"
            }
          ]
        },
        "options": {}
      },
      "id": "set-update-fields-9012",
      "name": "Mapear Update DB",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        640,
        500
      ]
    },
    {
      "parameters": {
        "operation": "update",
        "schema": "public",
        "table": "conteudos_marketing",
        "updateKey": "id",
        "columns": "status",
        "dataMode": "autoMapInputData",
        "options": {}
      },
      "id": "e5d4c3b2-a1f0-9e8d-7c6b-5a4f3e2d1c0b",
      "name": "Atualizar Status (Publicado)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.1,
      "position": [
        860,
        500
      ],
      "credentials": {
        "postgres": {
          "id": "supabase-db",
          "name": "Supabase"
        }
      }
    }
  ],
  "connections": {
    "Cron (Segunda 10h)": {
      "main": [
        [
          {
            "node": "Selecionar Tema Automático",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Selecionar Tema Automático": {
      "main": [
        [
          {
            "node": "Gerar Copy (OpenAI)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Gerar Copy (OpenAI)": {
      "main": [
        [
          {
            "node": "Mapear Campos DB",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Mapear Campos DB": {
      "main": [
        [
          {
            "node": "Salvar Pendente Aprovação",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Webhook (dl-aprovar-post)": {
      "main": [
        [
          {
            "node": "Postar na Meta",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Postar na Meta": {
      "main": [
        [
          {
            "node": "Mapear Update DB",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Mapear Update DB": {
      "main": [
        [
          {
            "node": "Atualizar Status (Publicado)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    {
      "name": "Marketing"
    }
  ]
}
