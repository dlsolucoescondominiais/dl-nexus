{
  "name": "020 - Publicador Social (Validador KILLCRITIC)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "dl-validar-killcritic",
        "options": {}
      },
      "id": "e0b5c1a8-9d4f-4b3a-8c2e-1f5d6a7b8c9e",
      "name": "Webhook (dl-validar-killcritic)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        200,
        300
      ],
      "webhookId": "dl-validar-killcritic"
    },
    {
      "parameters": {
        "jsCode": "let content = $json.body.copy_gerada;\n\n// 1. Substituições obrigatórias\ncontent = content.replace(/visita t[é|e]cnica/gi, 'Avaliação Técnica');\ncontent = content.replace(/Condfy/gi, 'Fortress');\ncontent = content.replace(/engenheiro/gi, 'Tecnólogo Responsável');\n\n// 2. Validações de bloqueio\nlet isValid = true;\nlet errorMsg = '';\n\nif (!content.includes('https://dlsolucoescondominiais.com')) {\n  isValid = false;\n  errorMsg = 'Erro: Conteúdo sem CTA principal.';\n}\n\nif (content.toLowerCase().includes('visita técnica')) {\n  isValid = false;\n  errorMsg = 'Erro: A expressão proibida \"visita técnica\" ainda está presente.';\n}\n\nreturn [\n  {\n    json: {\n      isValid: isValid,\n      errorMsg: errorMsg,\n      copy_aprovada: content,\n      tema: $json.body.tema\n    }\n  }\n];"
      },
      "id": "code-killcritic-1235",
      "name": "Validar Protocolo KILLCRITIC",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.isValid }}",
              "value2": true
            }
          ]
        }
      },
      "id": "if-node-valid-1236",
      "name": "É Válido?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        640,
        300
      ]
    },
    {
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "string": [
            {
              "name": "tipo",
              "value": "educativo"
            },
            {
              "name": "problema",
              "value": "automacao"
            },
            {
              "name": "copy_gerada",
              "value": "={{ $json.copy_aprovada }}"
            },
            {
              "name": "status",
              "value": "agendado"
            }
          ]
        },
        "options": {}
      },
      "id": "set-node-fields-5679",
      "name": "Mapear Campos DB",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        860,
        200
      ]
    },
    {
